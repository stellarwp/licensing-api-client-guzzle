{
    "name": "stellarwp/licensing-api-client-guzzle",
    "type": "library",
    "description": "Guzzle transport and factory integration for the v4 StellarWP Licensing API client.",
    "license": "GPL-2.0-or-later",
    "config": {
        "vendor-dir": "vendor",
        "preferred-install": "dist"
    },
    "require": {
        "php": ">=7.4",
        "stellarwp/licensing-api-client": "^0.1.1",
        "guzzlehttp/guzzle": "^7.10",
        "guzzlehttp/psr7": "^2.9"
    },
    "autoload": {
        "psr-4": {
            "StellarWP\\LicensingApiClientGuzzle\\": "src/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.2.x-dev"
        }
    }
}
